# ─────────────────────────────────────────────
# StudyFlow Backend - Variables d'environnement
# COPIER ce fichier en .env et NE PAS le committer sur GitHub !
# ─────────────────────────────────────────────

# Django
SECRET_KEY=django-insecure-changez-moi-en-production-avec-une-vraie-cle-secrete
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Base de données (SQLite par défaut, PostgreSQL en production)
DATABASE_URL=sqlite:///db.sqlite3
# Pour PostgreSQL: DATABASE_URL=postgres://user:password@localhost:5432/studyflow_db

# CORS - Origines autorisées (frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
